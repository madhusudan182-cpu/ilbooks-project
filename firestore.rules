rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // These rules are open for development purposes as the application
    // uses a mock authentication system. In a real-world application,
    // these would be secured based on user authentication and roles.
    
    // Deployment trigger: Explicitly allowing recursive access to collections.
    // FORCE REDEPLOYMENT ID: 1712345678901 (Resetting permissions for support_tickets)

    match /users/{userId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
       allow read, write: if true;
    }

    // Using a recursive wildcard {allPaths=**} to ensure the collection
    // and its contents are fully accessible during the 'list' operation.
    match /support_tickets/{allPaths=**} {
      allow read, write: if true;
    }

    match /syllabi/{level} {
      allow read, write: if true;
    }

    match /books/{bookId} {
      allow read, write: if true;
    }

    match /questions/{questionId} {
      allow read, write: if true;
    }
  }
}