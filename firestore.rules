rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // These rules are open for development purposes as the application
    // uses a mock authentication system. In a real-world application,
    // these would be secured based on user authentication and roles.
    
    // FORCE REDEPLOYMENT ID: 1741122700000 (Triggering global permission update)

    match /users/{userId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
       allow read, write: if true;
    }

    match /support_tickets/{ticketId} {
      allow read, write: if true;
    }

    match /syllabi/{level} {
      allow read, write: if true;
    }

    match /books/{bookId} {
      allow read, write: if true;
    }

    match /questions/{questionId} {
      allow read, write: if true;
    }
  }
}