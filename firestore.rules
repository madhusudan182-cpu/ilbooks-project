rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // These rules are open for development purposes as the application
    // uses a mock authentication system. In a real-world application,
    // these would be secured based on user authentication and roles.
    
    // Deployment trigger: Ensuring support_tickets list operations are explicitly allowed.
    // Forced re-sync timestamp: 2024-06-05T12:30:00Z

    match /users/{userId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
       allow read, write: if true;
    }

    match /support_tickets/{ticketId} {
      allow read, write: if true;
    }

    match /syllabi/{level} {
      allow read, write: if true;
    }

    match /books/{bookId} {
      allow read, write: if true;
    }

    match /questions/{questionId} {
      allow read, write: if true;
    }
  }
}