rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // These rules are open for development purposes as the application
    // uses a mock authentication system. In a real-world application,
    // these would be secured based on user authentication and roles.
    
    // FORCE REDEPLOYMENT ID: 1741122445566 (System-wide permission refresh)

    match /users/{userId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
       allow read, write: if true;
    }

    // Explicitly allow both collection-level queries and document-level access
    match /support_tickets {
      allow read, write, list: if true;
      match /{ticketId} {
        allow read, write: if true;
      }
    }

    match /syllabi/{level} {
      allow read, write: if true;
    }

    match /books/{bookId} {
      allow read, write: if true;
    }

    match /questions/{questionId} {
      allow read, write: if true;
    }
  }
}